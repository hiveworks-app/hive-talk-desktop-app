{
  "name": "hiveworks-web",
  "version": "0.1.5",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev -p 23000",
    "build": "next build",
    "start": "next start -p 23000",
    "lint": "eslint",
    "electron:compile": "tsc -p electron/tsconfig.json && cp electron/notification.html dist-electron/notification.html",
    "electron:dev": "npm run electron:compile && concurrently -n next,electron \"next dev -p 23000\" \"wait-on http://localhost:23000 && electron .\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron:pack": "npm run build && npm run electron:compile && electron-builder --dir"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stomp/stompjs": "^7.3.0",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "idb-keyval": "^6.2.2",
    "lottie-react": "^2.4.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-virtuoso": "^4.18.1",
    "tailwind-merge": "^3.5.0",
    "uuidv7": "^1.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
